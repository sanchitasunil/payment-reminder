#Can be set to openai/deepgram
STT_PROVIDER=openai
#Can be set to - gemini/openai/opencode
LLM_PROVIDER=openai

#Get these from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=your-project-id.sip.livekit.cloud

#Get this from https://deepgram.com
DEEPGRAM_API_KEY=

#Get this from https://aistudio.google.com
GOOGLE_API_KEY=

#Get this from https://murf.ai/api/dashboard
MURF_API_KEY=

#Get these from Twilio Console - https://console.twilio.com or https://1console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+12015551234
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# For production: whatsapp:+1XXXXXXXXXX (approved Twilio WhatsApp Business number)
# Handoff — the real clinic phone number Aria transfers calls to (E.164)
CLINIC_PHONE_NUMBER=+15550001234

#Get these from https://supabase.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key

# Google Calendar mirror (optional — agent works without this)
#Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_CREDENTIALS_JSON=./service-account.json
GOOGLE_CALENDAR_ID_SARAH=xxxxxxx@group.calendar.google.com
GOOGLE_CALENDAR_ID_JAMES=xxxxxxx@group.calendar.google.com

